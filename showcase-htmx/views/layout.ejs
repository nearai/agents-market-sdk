<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Wholesale Gorilla Admin' %></title>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <link rel="stylesheet" href="/styles.css">
  <script src="/applicant-review-card.js"></script>
  <script src="/api/nearai/widget.js"></script>
</head>
<body>
  <nav class="topbar">
    <div class="topbar__brand">
      <span class="topbar__icon">🦍</span>
      <span class="topbar__name">Wholesale Gorilla</span>
    </div>
    <div class="topbar__nav">
      <a href="/" class="topbar__link">New Application</a>
      <a href="/jobs" class="topbar__link">Jobs</a>
    </div>
  </nav>
  <main class="main">
    <%- body %>
  </main>

  <!-- Modal overlay for AI review widget -->
  <div id="review-modal" class="modal" style="display:none">
    <div class="modal__backdrop" onclick="closeReviewModal()"></div>
    <div class="modal__content">
      <button class="modal__close" onclick="closeReviewModal()">&times;</button>
      <div id="review-widget"></div>
    </div>
  </div>

  <script>
    function openReviewModal() {
      document.getElementById('review-modal').style.display = 'flex';
    }
    function closeReviewModal() {
      document.getElementById('review-modal').style.display = 'none';
    }
  </script>
</body>
</html>
